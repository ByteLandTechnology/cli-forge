# release-receipt.yml
#
# Generated by the Publish stage (Stage 6) after completing a release activity.
# Optionally consumed by Distribute (Stage 7) as repo-native release evidence.
# Stored at: <target-project>/.cli-forge/release-receipt.yml

project: "{{skill_name}}"
project_path: "{{project_path}}"
timestamp: "{{iso8601_timestamp}}"

release_mode: "{{report_only|dry_run|rehearsal|live_release}}"

version: "{{semver}}"
git_tag: "v{{semver}}"
repository: "{{repo_url}}"

asset_pack_adopted: "{{true|false}}"
install_helper_path: "scripts/install-current-release.sh"

evidence:
  release_evidence_json: "{{true|false}}"
  github_release_url: "{{url}}"
  binary_targets:
    - "{{target_triple}}"

validation_report_ref: "./validation-report.yml"

outcome: "{{success|dry_run_reviewed|rehearsal_staged|report_delivered}}"
